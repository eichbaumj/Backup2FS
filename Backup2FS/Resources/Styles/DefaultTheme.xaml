    <!-- B-Tree Visualizer Page Type Colors (aligned with Elusive Data brand) -->
    <SolidColorBrush x:Key="BTreeSchemaRootBrush" Color="#F37934"/>
    <SolidColorBrush x:Key="BTreeInteriorTableBrush" Color="#F37934"/>
    <SolidColorBrush x:Key="BTreeLeafTableBrush" Color="#4CAF50"/>
    <SolidColorBrush x:Key="BTreeInteriorIndexBrush" Color="#87CEEB"/>
    <SolidColorBrush x:Key="BTreeLeafIndexBrush" Color="#1976D2"/>
    <SolidColorBrush x:Key="BTreeFreelistTrunkBrush" Color="#EE3D53"/>
    <SolidColorBrush x:Key="BTreeFreelistLeafBrush" Color="#EE3D53"/>
    <SolidColorBrush x:Key="BTreeOverflowBrush" Color="#5DA9C8"/>
    <SolidColorBrush x:Key="BTreePointerMapBrush" Color="#64748B"/>
    <SolidColorBrush x:Key="BTreeUnknownBrush" Color="#4A5568"/>

    <!-- ============================================================= -->
    <!-- Clario landing - module colors & card surface (theme-aware)    -->
    <!-- ============================================================= -->

    <!-- Module accent colors (brand identity - constant across themes) -->
    <SolidColorBrush x:Key="ModuleSqliteBrush"  Color="#3B82F6"/>
    <SolidColorBrush x:Key="ModuleLevelDbBrush" Color="#F37934"/>
    <!-- RealmDB: gradient sphere echoing the Realm logo (sunset top -> indigo base) -->
    <LinearGradientBrush x:Key="ModuleRealmBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0.0"  Color="#F6A47B"/>
        <GradientStop Offset="0.28" Color="#EE6FA0"/>
        <GradientStop Offset="0.52" Color="#C9447F"/>
        <GradientStop Offset="0.74" Color="#7E51A8"/>
        <GradientStop Offset="1.0"  Color="#45568F"/>
    </LinearGradientBrush>
    <SolidColorBrush x:Key="ModuleIndexedBrush" Color="#F8A055"/>
    <SolidColorBrush x:Key="ModulePlistBrush"   Color="#4ADE80"/>
    <SolidColorBrush x:Key="ModuleXmlBrush"     Color="#FACC15"/>
    <SolidColorBrush x:Key="ModuleJsonBrush"  Color="#2DD4BF"/>
    <SolidColorBrush x:Key="ModuleHexBrush"     Color="#F43F5E"/>
    <SolidColorBrush x:Key="ModuleSegbBrush"    Color="#C2C8D0"/>  <!-- Mac aluminium silver -->

    <!-- Soft chip tints: identical two-stop gradient treatment for every module
         (lit at the top, fading down) so all eight tiles share one luminance band. -->
    <LinearGradientBrush x:Key="ModuleSqliteSoftBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#383B82F6" Offset="0"/><GradientStop Color="#143B82F6" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="ModuleLevelDbSoftBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#38F37934" Offset="0"/><GradientStop Color="#14F37934" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="ModuleRealmSoftBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#38A855F7" Offset="0"/><GradientStop Color="#14A855F7" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="ModuleIndexedSoftBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#38F8A055" Offset="0"/><GradientStop Color="#14F8A055" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="ModulePlistSoftBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#384ADE80" Offset="0"/><GradientStop Color="#144ADE80" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="ModuleXmlSoftBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#38FACC15" Offset="0"/><GradientStop Color="#14FACC15" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="ModuleJsonSoftBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#382DD4BF" Offset="0"/><GradientStop Color="#142DD4BF" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="ModuleHexSoftBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#38F43F5E" Offset="0"/><GradientStop Color="#14F43F5E" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="ModuleSegbSoftBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#38C2C8D0" Offset="0"/><GradientStop Color="#14C2C8D0" Offset="1"/>
    </LinearGradientBrush>

    <!-- Splash backdrop: barely-there vertical grade so the area around the landing
         panel has depth instead of reading as flat fill. -->
    <LinearGradientBrush x:Key="SplashBackdropBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#1C2C42" Offset="0"/>
        <GradientStop Color="#162535" Offset="0.45"/>
        <GradientStop Color="#101B28" Offset="1"/>
    </LinearGradientBrush>

    <!-- Faint dot grid for the schema diagram canvas — signals a pannable/zoomable
         workspace. Lives on the in-canvas background rect, so it pans and zooms
         with the table cards. -->
    <DrawingBrush x:Key="CanvasDotGridBrush" TileMode="Tile" Viewport="0,0,28,28" ViewportUnits="Absolute" Stretch="None">
        <DrawingBrush.Drawing>
            <GeometryDrawing Brush="#17FFFFFF">
                <GeometryDrawing.Geometry>
                    <EllipseGeometry Center="14,14" RadiusX="1.2" RadiusY="1.2"/>
                </GeometryDrawing.Geometry>
            </GeometryDrawing>
        </DrawingBrush.Drawing>
    </DrawingBrush>

    <!-- Module card surface (subtle vertical gradient) -->
    <LinearGradientBrush x:Key="ModuleCardGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#1B2D42" Offset="0.0"/>
        <GradientStop Color="#142233" Offset="1.0"/>
    </LinearGradientBrush>

</ResourceDictionary>
