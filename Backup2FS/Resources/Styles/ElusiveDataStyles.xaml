<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <!--
    ========================================
    ELUSIVE DATA STYLES
    ========================================
    This file contains all button, control, and UI element styles.
    Colors are now dynamically provided by theme files:
    - DefaultTheme.xaml (branded blue theme)
    - DarkTheme.xaml (high-contrast dark)
    - LightTheme.xaml (professional light)

    All color keys reference the currently loaded theme.
    ========================================
    -->

    <!-- Gradient brush for table headers -->
    <LinearGradientBrush x:Key="ElusiveDataHeaderGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="{StaticResource ElusiveDataRed}" Offset="0.0" />
        <GradientStop Color="{StaticResource ElusiveDataOrange}" Offset="1.0" />
    </LinearGradientBrush>

    <!--
    ========================================
    SUITE-STANDARD CONTENT TAB
    ========================================
    Canonical tab look for every content TabControl in the suite (SQLite
    Analyzer's Database/WAL/Journal/Freelist tabs, the JSON / Plist viewers,
    and any future viewer). On selection a tab gets an orange highlight fill
    plus a 2px orange bottom border, and its label + icon recolor to orange;
    hover shows a lighter orange tint. Foreground is inherited so the icon and
    text recolor together.

    Apply directly (Style="{StaticResource ContentTabItem}") OR, when a
    TabControl needs per-tab sub-styles, declare an implicit TabItem style
    BasedOn this key inside that control's resources so bare tabs pick it up.
    -->
    <Style x:Key="ContentTabItem" TargetType="TabItem">
        <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="0"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border x:Name="TabBorder"
                            Background="Transparent"
                            BorderThickness="0,0,0,2"
                            BorderBrush="Transparent"
                            Padding="16,8"
                            Cursor="Hand">
                        <ContentPresenter ContentSource="Header"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource ElusiveDataOrangeBrush}"/>
                            <Setter TargetName="TabBorder" Property="Background" Value="#33F37934"/>
                            <Setter Property="Foreground" Value="{DynamicResource ElusiveDataOrangeBrush}"/>
                        </Trigger>
                        <!-- Hover tint only on UNselected tabs — applying it to the selected tab fought the
                             IsSelected background (#33 ↔ #22) and made the active tab flicker on mouse move. -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True"/>
                                <Condition Property="IsSelected" Value="False"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="TabBorder" Property="Background" Value="#22F37934"/>
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
    ========================================
    FORENSIC STATUS BRUSHES (P2C-05)
    ========================================
    Single canonical color set for the forensic record-status columns
    (CommitStatus + StatusText) used in Recovered WAL Records, Recovered
    Freelist Records, and any future status grids. Per the brand spec:

      Active            green   (currently committed)
      Staged            sky blue (will commit on checkpoint)
      Inactive          gray    (older session / superseded)
      Freelist          sky blue (recovered from freelist — same blue band as Staged)
      Orphaned          amber   (older session — page reachable but not current)
      PendingUpdate     orange  (DB record will be modified on commit)
      PendingDeletion   red     (DB record will be removed on commit)
      Deleted           red     (record was intentionally deleted in WAL)

    Defined as static resources so Window.Resources don't need to redeclare
    them. The underlying ElusiveData* color resources are theme-aware (each
    of DefaultTheme/DarkTheme/LightTheme provides its own palette), so these
    brushes pick up the active theme at parse time.
    ========================================
    -->
    <SolidColorBrush x:Key="ForensicActiveBrush" Color="{StaticResource ElusiveDataCommitGreen}" />
    <SolidColorBrush x:Key="ForensicStagedBrush" Color="{StaticResource ElusiveDataSkyBlue}" />
    <SolidColorBrush x:Key="ForensicInactiveBrush" Color="#CCCCCC" />
    <SolidColorBrush x:Key="ForensicFreelistBrush" Color="{StaticResource ElusiveDataSkyBlue}" />
    <SolidColorBrush x:Key="ForensicOrphanedBrush" Color="#FFC107" />
    <SolidColorBrush x:Key="ForensicPendingUpdateBrush" Color="{StaticResource ElusiveDataOrange}" />
    <SolidColorBrush x:Key="ForensicPendingDeletionBrush" Color="{StaticResource ElusiveDataRed}" />
    <SolidColorBrush x:Key="ForensicDeletedBrush" Color="{StaticResource ElusiveDataRed}" />

