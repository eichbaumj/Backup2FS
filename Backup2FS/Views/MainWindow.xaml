<Window x:Class="Backup2FS.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Backup2FS.Views"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:Backup2FS.ViewModels"
        xmlns:converters="clr-namespace:Backup2FS.Converters"
        mc:Ignorable="d"
        Title="Backup2FS"
        Height="950"
        Width="1300"
        MinHeight="600"
        MinWidth="900"
        Icon="pack://application:,,,/Resources/Icons/app_icon.ico"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource WindowBackgroundBrush}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        FontFamily="{DynamicResource MaterialDesignFont}"
        WindowStartupLocation="CenterScreen">

    <!-- Borderless custom chrome: the 60px brand ribbon becomes the caption area (drag,
         double-click maximize, right-click system menu) via CaptionHeight. Min/max/close are
         our own buttons in the ribbon. GlassFrameThickness keeps a sliver of DWM frame so the
         window retains its drop shadow and Win11 rounded corners. -->
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="60"
                      ResizeBorderThickness="6"
                      CornerRadius="0"
                      GlassFrameThickness="0,0,0,1"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Style for info button -->
        <Style x:Key="IconButtonStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignIconButton}">
            <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
        </Style>
        <converters:BooleanToPauseResumeTextConverter x:Key="BooleanToPauseResumeTextConverter"/>
    </Window.Resources>

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <materialDesign:DialogHost Identifier="RootDialog">
        <DockPanel>
            <!-- Brand ribbon (doubles as the window caption via WindowChrome) -->
            <Border DockPanel.Dock="Top" Background="{DynamicResource RibbonGradientBrush}" Height="60">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Wordmark (no logo image, orange brand color over the gradient) -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0,0,0">
                        <TextBlock Text="Backup" FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource ElusiveDataOrangeBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="2FS" FontSize="20" FontWeight="Light"
                                   Foreground="White" Margin="2,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Icon buttons + window controls -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center"
                                WindowChrome.IsHitTestVisibleInChrome="True">
                        <!-- New Session (re-scan) -->
                        <Button Style="{StaticResource HeaderButtonStyle}" ToolTip="New Session"
                                Command="{Binding NewSessionCommand}" IsEnabled="{Binding IsProcessing}">
                            <materialDesign:PackIcon Kind="Restart" Width="24" Height="24"/>
                        </Button>
                        <!-- Settings -->
                        <Button Style="{StaticResource HeaderButtonStyle}" ToolTip="Settings" Click="SettingsButton_Click">
                            <materialDesign:PackIcon Kind="Settings" Width="24" Height="24"/>
                        </Button>
                        <!-- About -->
                        <Button Style="{StaticResource HeaderButtonStyle}" ToolTip="About" Click="InfoButton_Click">
                            <materialDesign:PackIcon Kind="Information" Width="24" Height="24"/>
                        </Button>
                        <!-- Help -->
                        <Button Style="{StaticResource HeaderButtonStyle}" ToolTip="Help" Click="HelpButton_Click">
                            <materialDesign:PackIcon Kind="HelpCircle" Width="24" Height="24"/>
                        </Button>

                        <Border Width="1" Height="24" Background="{DynamicResource RibbonDividerBrush}" Margin="8,0,4,0"/>

                        <!-- Window controls -->
                        <Button Style="{StaticResource CaptionButtonStyle}" Click="TitleBarMinimize_Click" ToolTip="Minimize">
                            <materialDesign:PackIcon Kind="WindowMinimize" Width="16" Height="16"/>
                        </Button>
                        <Button x:Name="MaximizeButton" Style="{StaticResource CaptionButtonStyle}" Click="TitleBarMaximizeRestore_Click" ToolTip="Maximize">
                            <materialDesign:PackIcon x:Name="MaximizeIcon" Kind="WindowMaximize" Width="16" Height="16"/>
                        </Button>
                        <Button Style="{StaticResource CaptionCloseButtonStyle}" Click="TitleBarClose_Click" ToolTip="Close">
                            <materialDesign:PackIcon Kind="WindowClose" Width="16" Height="16"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Status bar -->
            <Border DockPanel.Dock="Bottom" Background="{DynamicResource RibbonGradientBrush}" Height="30">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,15,0">
                    <TextBlock Text="Backup2FS" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <TextBlock Text="Build: 3.0" Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Main Content -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="420"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Left Side - Device Info and Apps -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Left Panel - Device Info -->
                    <materialDesign:Card Grid.Row="0" Margin="20,20,10,10" 
                                       materialDesign:ShadowAssist.ShadowDepth="Depth3" 
                                       Background="{DynamicResource ElusiveDataBlueBrush}"
                                       VerticalAlignment="Top">
                        <DockPanel VerticalAlignment="Stretch">
                            <TextBlock DockPanel.Dock="Top" Text="Device Information" 
                                     Style="{StaticResource MaterialDesignHeadline6TextBlock}" 
                                     Margin="16,16,16,0" 
                                     Foreground="{DynamicResource ElusiveDataLightGrayBrush}"/>
                            
                            <ScrollViewer DockPanel.Dock="Top" Margin="16" Height="385" 
                                         VerticalScrollBarVisibility="Auto">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Device Name:" 
                                             Style="{StaticResource MaterialDesignBody1TextBlock}" 
                                             Margin="0,4" FontSize="12"
                                             Foreground="{DynamicResource ElusiveDataLightGrayBrush}"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding DeviceName}" 
                                             Style="{StaticResource MaterialDesignBody1TextBlock}" 
                                             Margin="0,4" FontSize="12"
                                             Foreground="{DynamicResource ElusiveDataLightGrayBrush}"/>
                                    
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Model:" 
                                             Style="{StaticResource MaterialDesignBody1TextBlock}" 
                                             Margin="0,4" FontSize="12"
                                             Foreground="{DynamicResource ElusiveDataLightGrayBrush}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Model}" 
                                             Style="{StaticResource MaterialDesignBody1TextBlock}" 
                                             Margin="0,4" FontSize="12"
                                             Foreground="{DynamicResource ElusiveDataLightGrayBrush}"/>
                                    
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="iOS Version:" 
                                             Style="{StaticResource MaterialDesignBody1TextBlock}" 
                                             Margin="0,4" FontSize="12"
                                             Foreground="{DynamicResource ElusiveDataLightGrayBrush}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding IosVersion}" 
                                             Style="{StaticResource MaterialDesignBody1TextBlock}" 
                                             Margin="0,4" FontSize="12"
                                             Foreground="{DynamicResource ElusiveDataLightGrayBrush}"/>
                                    
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Build Version:" 
                                             Style="{StaticResource MaterialDesignBody1TextBlock}" 
                                             Margin="0,4" FontSize="12"
                                             Foreground="{DynamicResource ElusiveDataLightGrayBrush}"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding BuildVersion}" 
                                             Style="{StaticResource MaterialDesignBody1TextBlock}" 
                                             Margin="0,4" FontSize="12"
                                             Foreground="{DynamicResource ElusiveDataLightGrayBrush}"/>
                                    
                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Serial Number:" 
                                             Style="{StaticResource MaterialDesignBody1TextBlock}" 
                                             Margin="0,4" FontSize="12"
                                             Foreground="{DynamicResource ElusiveDataLightGrayBrush}"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SerialNumber}" 
                                             Style="{StaticResource MaterialDesignBody1TextBlock}" 
                                             Margin="0,4" FontSize="12"
                                             Foreground="{DynamicResource ElusiveDataLightGrayBrush}"/>
                                    
                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Unique Device ID:" 
                                             Style="{StaticResource MaterialDesignBody1TextBlock}" 
                                             Margin="0,4" FontSize="12"
                                             Foreground="{DynamicResource ElusiveDataLightGrayBrush}"/>
                                    <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding UniqueDeviceId}" 
                                             Style="{StaticResource MaterialDesignBody1TextBlock}" 
                                             Margin="0,4" FontSize="12" TextWrapping="Wrap"
                                             Foreground="{DynamicResource ElusiveDataLightGrayBrush}"/>
                                    
                                    <TextBlock Grid.Row="6" Grid.Column="0" Text="IMEI:" 
                                             Style="{StaticResource MaterialDesignBody1TextBlock}" 
                                             Margin="0,4" FontSize="12"
                                             Foreground="{DynamicResource ElusiveDataLightGrayBrush}"/>
                                    <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding Imei}" 
                                             Style="{StaticResource MaterialDesignBody1TextBlock}" 
                                             Margin="0,4" FontSize="12"
                                             Foreground="{DynamicResource ElusiveDataLightGrayBrush}"/>
                                    
                                    <TextBlock Grid.Row="7" Grid.Column="0" Text="MEID:" 
                                             Style="{StaticResource MaterialDesignBody1TextBlock}" 
                                             Margin="0,4" FontSize="12"
                                             Foreground="{DynamicResource ElusiveDataLightGrayBrush}"/>
                                    <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding Meid}" 
                                             Style="{StaticResource MaterialDesignBody1TextBlock}" 
                                             Margin="0,4" FontSize="12"
                                             Foreground="{DynamicResource ElusiveDataLightGrayBrush}"/>
                                    
                                    <TextBlock Grid.Row="8" Grid.Column="0" Text="ICCID:" 
                                             Style="{StaticResource MaterialDesignBody1TextBlock}" 
                                             Margin="0,4" FontSize="12"
                                             Foreground="{DynamicResource ElusiveDataLightGrayBrush}"/>
                                    <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding Iccid}" 
                                             Style="{StaticResource MaterialDesignBody1TextBlock}" 
                                             Margin="0,4" FontSize="12"
                                             Foreground="{DynamicResource ElusiveDataLightGrayBrush}"/>
                                    
                                    <TextBlock Grid.Row="9" Grid.Column="0" Text="Encrypted:" 
                                             Style="{StaticResource MaterialDesignBody1TextBlock}" 
                                             Margin="0,4" FontSize="12"
                                             Foreground="{DynamicResource ElusiveDataLightGrayBrush}"/>
                                    <TextBlock Grid.Row="9" Grid.Column="1" Text="{Binding IsEncrypted}" 
                                             Style="{StaticResource MaterialDesignBody1TextBlock}" 
                                             Margin="0,4" FontSize="12"
                                             Foreground="{DynamicResource ElusiveDataLightGrayBrush}"/>
                                    
                                    <TextBlock Grid.Row="10" Grid.Column="0" Text="Phone Number:" 
                                             Style="{StaticResource MaterialDesignBody1TextBlock}" 
                                             Margin="0,4" FontSize="12"
                                             Foreground="{DynamicResource ElusiveDataLightGrayBrush}"/>
                                    <TextBlock Grid.Row="10" Grid.Column="1" Text="{Binding PhoneNumber}" 
                                             Style="{StaticResource MaterialDesignBody1TextBlock}" 
                                             Margin="0,4" FontSize="12"
                                             Foreground="{DynamicResource ElusiveDataLightGrayBrush}"/>
                                    
                                    <TextBlock Grid.Row="11" Grid.Column="0" Text="Backup Date:" 
                                             Style="{StaticResource MaterialDesignBody1TextBlock}" 
                                             Margin="0,4" FontSize="12"
                                             Foreground="{DynamicResource ElusiveDataLightGrayBrush}"/>
                                    <TextBlock Grid.Row="11" Grid.Column="1" Text="{Binding LastBackupDate}" 
                                             Style="{StaticResource MaterialDesignBody1TextBlock}" 
                                             Margin="0,4" FontSize="12"
                                             Foreground="{DynamicResource ElusiveDataLightGrayBrush}"/>
                                </Grid>
                            </ScrollViewer>
                        </DockPanel>
                    </materialDesign:Card>
                    
                    <!-- Installed Apps -->
                    <materialDesign:Card Grid.Row="1" Margin="20,0,10,20" 
                                      materialDesign:ShadowAssist.ShadowDepth="Depth3"
                                      Background="{DynamicResource ElusiveDataBlueBrush}">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="Installed Apps" 
                                     Style="{StaticResource MaterialDesignHeadline6TextBlock}" 
                                     Margin="16,16,16,0"
                                     Foreground="{DynamicResource ElusiveDataLightGrayBrush}"/>
                            
                            <ListBox Margin="16" ItemsSource="{Binding InstalledApps}" 
                                   ScrollViewer.VerticalScrollBarVisibility="Auto" 
                                   HorizontalContentAlignment="Stretch"
                                   Background="Transparent"
                                   BorderThickness="0"
                                   VirtualizingPanel.IsVirtualizing="True"
                                   VirtualizingPanel.VirtualizationMode="Recycling"
                                   VirtualizingPanel.ScrollUnit="Pixel"
                                   VirtualizingPanel.CacheLength="5"
                                   ScrollViewer.IsDeferredScrollingEnabled="False"
                                   Foreground="{DynamicResource ElusiveDataLightGrayBrush}">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                        <Setter Property="Padding" Value="8,6"/>
                                        <Setter Property="Margin" Value="0,2"/>
                                        <Setter Property="Background" Value="#21354D"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border Background="{TemplateBinding Background}"
                                                           BorderBrush="{TemplateBinding BorderBrush}"
                                                           BorderThickness="{TemplateBinding BorderThickness}"
                                                           CornerRadius="4"
                                                           Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter Property="Background" Value="#2C4560"/>
                                                        </Trigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#2C4560"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <!-- App Icon -->
                                            <Grid Grid.Column="0" Width="40">
                                                <Grid Width="30" Height="30" Margin="3,0">
                                                    <!-- Background icon (always visible) -->
                                                    <materialDesign:PackIcon Kind="ApplicationOutline" 
                                                                          Width="24" Height="24"
                                                                          HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"
                                                                          Foreground="LightGray"/>
                                                    
                                                    <!-- Actual app icon (visible when HasIcon is true) -->
                                                    <Image Width="24" Height="24"
                                                          Source="{Binding IconImage}" 
                                                          RenderOptions.BitmapScalingMode="HighQuality"
                                                          Stretch="Uniform"
                                                          SnapsToDevicePixels="True"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"
                                                          CacheMode="BitmapCache"
                                                          Visibility="{Binding HasIcon, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                </Grid>
                                            </Grid>
                                            
                                            <!-- App Name/Bundle ID with DisplayName fallback -->
                                            <TextBlock Grid.Column="1" 
                                                      Text="{Binding DisplayName}"
                                                      TextTrimming="CharacterEllipsis"
                                                      VerticalAlignment="Center"
                                                      FontSize="13"
                                                      Foreground="White">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding DisplayName}" Value="{x:Null}">
                                                                <Setter Property="Text" Value="{Binding BundleId}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding DisplayName}" Value="">
                                                                <Setter Property="Text" Value="{Binding BundleId}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </materialDesign:Card>
                </Grid>
                
                <!-- Right Side - Controls and Log -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="1*"/>
                        <RowDefinition Height="2*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Right Panel - Main Controls -->
                    <Grid Grid.Row="0" Margin="10,20,20,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <!-- iOS Backup Normalizer Title -->
                        <TextBlock Grid.Row="0" Text="iOS Backup Normalizer" 
                                   Style="{StaticResource MaterialDesignHeadline5TextBlock}" 
                                   HorizontalAlignment="Center" 
                                   Margin="0,0,0,20"/>
                        
                        <!-- Folder Inputs -->
                        <Grid Grid.Row="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Backup Folder Row -->
                            <DockPanel Grid.Row="0" Margin="0,0,0,16">
                                <TextBlock DockPanel.Dock="Left" Text="Backup Folder" 
                                          VerticalAlignment="Center" Width="120" />
                                <Button DockPanel.Dock="Right" Margin="16,0,0,0"
                                       Command="{Binding BrowseBackupCommand}"
                                       Style="{StaticResource ElusiveDataWalSecondaryButton}">
                                    <TextBlock Text="Select" />
                                </Button>
                                <TextBox Text="{Binding BackupFolder, UpdateSourceTrigger=PropertyChanged}" 
                                        Style="{StaticResource MaterialDesignFilledTextBox}" />
                            </DockPanel>
                            
                            <!-- Destination Folder Row -->
                            <DockPanel Grid.Row="1" Margin="0,0,0,16">
                                <TextBlock DockPanel.Dock="Left" Text="Destination Folder" 
                                          VerticalAlignment="Center" Width="120" />
                                <Button DockPanel.Dock="Right" Margin="16,0,0,0"
                                       Command="{Binding BrowseOutputCommand}"
                                       Style="{StaticResource ElusiveDataWalSecondaryButton}">
                                    <TextBlock Text="Select" />
                                </Button>
                                <TextBox Text="{Binding OutputFolder, UpdateSourceTrigger=PropertyChanged}" 
                                        Style="{StaticResource MaterialDesignFilledTextBox}" />
                            </DockPanel>
                            
                            <!-- Normalize Button (the only orange action; matches the suite's
                                 "Analyze WAL Frames" primary button) -->
                            <Button Grid.Row="2" Content="Normalize"
                                   HorizontalAlignment="Center"
                                   Style="{StaticResource ElusiveDataWalPrimaryButton}"
                                   Command="{Binding NormalizeCommand}"
                                   IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBooleanConverter}}"
                                   Margin="0,16,0,0"
                                   Height="40"
                                   Width="200"/>
                        </Grid>
                    </Grid>
                    
                    <!-- Log Output Area -->
                    <Grid Grid.Row="1" Margin="10,0,20,20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <!-- Log TextBox -->
                        <TextBox Grid.Row="0" 
                                x:Name="LogTextBox"
                                Text="{Binding LogOutput, Mode=OneWay}" 
                                IsReadOnly="True" 
                                VerticalScrollBarVisibility="Auto"
                                HorizontalScrollBarVisibility="Auto"
                                TextWrapping="NoWrap"
                                FontFamily="Consolas"
                                Background="{DynamicResource MaterialDesignTextFieldBoxBackground}"
                                Padding="8"/>
                        
                        <!-- Progress Bar and Control Buttons -->
                        <Grid Grid.Row="1" Margin="0,8,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Progress Bar -->
                            <Grid Grid.Row="0">
                                <ProgressBar Style="{StaticResource ElusiveDataProgressBar}"
                                           Height="24" Minimum="0" Maximum="100"
                                           Value="{Binding ProgressValue}"/>
                                
                                <!-- Percentage Text Overlay -->
                                <TextBlock Text="{Binding ProgressValue, StringFormat='{}{0}%'}" 
                                         HorizontalAlignment="Center" 
                                         VerticalAlignment="Center" 
                                         Foreground="White" 
                                         FontWeight="Bold"/>
                            </Grid>
                            
                            <!-- Control Buttons -->
                            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                                <Button x:Name="PauseResumeButton"
                                        Content="{Binding IsPaused, Converter={StaticResource BooleanToPauseResumeTextConverter}, UpdateSourceTrigger=PropertyChanged, Mode=OneWay}"
                                        Command="{Binding PauseResumeCommand}"
                                        IsEnabled="{Binding IsNormalizing}"
                                        Style="{StaticResource ElusiveDataWalSecondaryButton}"
                                        Width="120"
                                        Margin="8,0"/>
                                
                                <Button Content="Cancel" 
                                       Style="{StaticResource ElusiveDataWalSecondaryButton}"
                                       Command="{Binding CancelCommand}" 
                                       IsEnabled="{Binding IsNormalizing}"
                                       Margin="8,0" Width="120"/>
                                
                                <Button Content="Save Log" 
                                       Style="{StaticResource ElusiveDataWalSecondaryButton}"
                                       Command="{Binding SaveLogCommand}" 
                                       IsEnabled="{Binding CanSaveLog}"
                                       Margin="8,0" Width="120"/>
                                
                                <Button Content="Open Folder"
                                       Style="{StaticResource ElusiveDataWalSecondaryButton}"
                                       Command="{Binding OpenFolderCommand}"
                                       IsEnabled="{Binding IsCompleted}"
                                       Margin="8,0" Width="120"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Grid>
            </Grid>
        </DockPanel>
    </materialDesign:DialogHost>
</Window> 