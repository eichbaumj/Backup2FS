<Window x:Class="Backup2FS.Views.NotificationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Backup2FS.Views"
        Title="Notification" 
        Height="Auto" Width="600"
        MinHeight="200" MaxHeight="700"
        MinWidth="500" MaxWidth="750"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        SizeToContent="Height">

    <Window.Resources>
        <!-- Fade in animation -->
        <Storyboard x:Key="FadeInAnimation">
            <DoubleAnimation 
                Storyboard.TargetProperty="Opacity"
                From="0" To="1" Duration="0:0:0.3"
                BeginTime="0:0:0"/>
            <DoubleAnimation 
                Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                From="0.9" To="1" Duration="0:0:0.3"/>
            <DoubleAnimation 
                Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                From="0.9" To="1" Duration="0:0:0.3"/>
        </Storyboard>
        
        <!-- Fade out animation -->
        <Storyboard x:Key="FadeOutAnimation">
            <DoubleAnimation 
                Storyboard.TargetProperty="Opacity"
                From="1" To="0" Duration="0:0:0.2"/>
            <DoubleAnimation 
                Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                From="1" To="0.9" Duration="0:0:0.2"/>
            <DoubleAnimation 
                Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                From="1" To="0.9" Duration="0:0:0.2"/>
        </Storyboard>

        <!-- Button style -->
        <Style x:Key="NotificationButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#F37934"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="Margin" Value="5,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="MinWidth" Value="80"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource SecondaryButtonHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{DynamicResource SecondaryButtonBackgroundBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary button style (with its own ControlTemplate for proper blue hover) -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource SecondaryButtonBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryButtonForegroundBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="Margin" Value="5,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="MinWidth" Value="80"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource SecondaryButtonHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{DynamicResource SecondaryButtonBackgroundBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Outer container with shadow -->
    <Border Background="Transparent" Padding="10">
        <Border x:Name="MainBorder"
                Background="{DynamicResource WindowBackgroundBrush}"
                CornerRadius="12"
                BorderBrush="#F37934"
                BorderThickness="2"
                RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
                <ScaleTransform ScaleX="1" ScaleY="1"/>
            </Border.RenderTransform>
            <Border.Effect>
                <DropShadowEffect Color="Black" 
                                Direction="270" 
                                ShadowDepth="5" 
                                BlurRadius="15" 
                                Opacity="0.5"/>
            </Border.Effect>
            
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header with icon and title -->
                <Border Grid.Row="0"
                        Background="{DynamicResource PanelBackgroundBrush}"
                        CornerRadius="10,10,0,0"
                        Padding="20,15">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="IconText" 
                                   Text="ℹ️" 
                                   FontSize="24" 
                                   VerticalAlignment="Center" 
                                   Margin="0,0,12,0"/>
                        <TextBlock x:Name="TitleText" 
                                   Text="Notification" 
                                   Foreground="#F37934" 
                                   FontSize="18" 
                                   FontWeight="Bold" 
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Content area -->
                <ScrollViewer Grid.Row="1" 
                              VerticalScrollBarVisibility="Auto" 
                              HorizontalScrollBarVisibility="Disabled"
                              MaxHeight="450">
                    <StackPanel Margin="20">
                        <!-- Main message -->
                        <TextBlock x:Name="MessageText" 
                                   Text="Your notification message here..." 
                                   Foreground="{DynamicResource PrimaryTextBrush}" 
                                   FontSize="14" 
                                   TextWrapping="Wrap" 
                                   LineHeight="20"
                                   Margin="0,0,0,15"/>
                        
                        <!-- Details section (optional) -->
                        <StackPanel x:Name="DetailsPanel" 
                                    Visibility="Collapsed" 
                                    Margin="0,0,0,15">
                            <Border Background="{DynamicResource InputBackgroundBrush}"
                                    CornerRadius="6"
                                    Padding="15">
                                <StackPanel>
                                    <TextBlock Text="Details:" 
                                               Foreground="{DynamicResource SecondaryTextBrush}" 
                                               FontWeight="SemiBold" 
                                               FontSize="12" 
                                               Margin="0,0,0,8"/>
                                    <ItemsControl x:Name="DetailsList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <!-- Orange bullet only for non-empty lines and non-summary lines -->
                                                    <TextBlock Grid.Column="0"
                                                               Foreground="#F37934" 
                                                               FontWeight="Bold" 
                                                               Margin="0,0,8,0"
                                                               VerticalAlignment="Top">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="•"/>
                                                                <Style.Triggers>
                                                                    <!-- Hide bullet for empty lines -->
                                                                    <DataTrigger Binding="{Binding}" Value="">
                                                                        <Setter Property="Text" Value=""/>
                                                                    </DataTrigger>
                                                                    <!-- Hide bullet for header line -->
                                                                    <DataTrigger Binding="{Binding}" Value="This will completely clear all loaded data:">
                                                                        <Setter Property="Text" Value=""/>
                                                                    </DataTrigger>
                                                                    <!-- Hide bullet for summary lines -->
                                                                    <DataTrigger Binding="{Binding Converter={x:Static local:StartsWithConverter.Instance}, ConverterParameter='The application will'}" Value="True">
                                                                        <Setter Property="Text" Value=""/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Converter={x:Static local:StartsWithConverter.Instance}, ConverterParameter='This action cannot'}" Value="True">
                                                                        <Setter Property="Text" Value=""/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding}" 
                                                               Foreground="{DynamicResource PrimaryTextBrush}" 
                                                               TextWrapping="Wrap"
                                                               VerticalAlignment="Top"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Progress indicator (optional) -->
                        <StackPanel x:Name="ProgressPanel" 
                                    Visibility="Collapsed" 
                                    Margin="0,0,0,15">
                            <TextBlock x:Name="ProgressText" 
                                       Text="Processing..." 
                                       Foreground="{DynamicResource SecondaryTextBrush}" 
                                       FontSize="12" 
                                       Margin="0,0,0,5"/>
                            <ProgressBar x:Name="ProgressBar"
                                         Height="4"
                                         Background="{DynamicResource DataGridBackgroundBrush}"
                                         Foreground="#F37934"
                                         Value="0"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <!-- Buttons -->
                <Border Grid.Row="2"
                        Background="{DynamicResource PanelBackgroundBrush}"
                        CornerRadius="0,0,10,10"
                        Padding="20,15">
                    <StackPanel x:Name="ButtonsPanel" 
                                Orientation="Horizontal" 
                                HorizontalAlignment="Right">
                        <!-- Buttons will be added dynamically -->
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Border>
</Window> 