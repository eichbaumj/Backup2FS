<Window x:Class="Backup2FS.Views.PasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="Encrypted Backup"
        Height="320" Width="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource WindowBackgroundBrush}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="64" ResizeBorderThickness="0" CornerRadius="0"
                      GlassFrameThickness="0,0,0,1" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="DecryptPrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ElusiveDataOrangeBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryButtonForegroundBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="Padding" Value="18,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource SecondaryButtonHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DecryptCancelButton" TargetType="Button" BasedOn="{StaticResource DecryptPrimaryButton}">
            <Setter Property="Background" Value="{DynamicResource SecondaryButtonBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
        </Style>
    </Window.Resources>

    <Grid Background="{DynamicResource ContentBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Banner -->
        <Border Grid.Row="0" Background="{DynamicResource AboutHeaderGradientBrush}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0,0,0">
                <materialDesign:PackIcon Kind="LockOutline" Width="26" Height="26" Foreground="White" VerticalAlignment="Center"/>
                <TextBlock Text="Encrypted Backup" FontSize="18" FontWeight="Bold" Foreground="White" Margin="12,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Content -->
        <StackPanel Grid.Row="1" Margin="24,20,24,8">
            <TextBlock Text="This backup is encrypted. Enter the iTunes backup password to decrypt it before normalizing."
                       Foreground="{DynamicResource PrimaryTextBrush}" TextWrapping="Wrap" FontSize="13" Margin="0,0,0,16"/>

            <TextBlock Text="Backup password" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12" Margin="0,0,0,4"/>

            <Grid>
                <PasswordBox x:Name="PasswordEntry" Height="34" FontSize="14" Padding="8,0"
                             VerticalContentAlignment="Center"
                             Background="{DynamicResource InputBackgroundBrush}"
                             Foreground="{DynamicResource PrimaryTextBrush}"
                             CaretBrush="{DynamicResource PrimaryTextBrush}"
                             BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1"
                             PasswordChanged="PasswordEntry_PasswordChanged"/>
                <TextBox x:Name="PlainEntry" Height="34" FontSize="14" Padding="8,0"
                         VerticalContentAlignment="Center" Visibility="Collapsed"
                         Background="{DynamicResource InputBackgroundBrush}"
                         Foreground="{DynamicResource PrimaryTextBrush}"
                         CaretBrush="{DynamicResource PrimaryTextBrush}"
                         BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1"
                         TextChanged="PlainEntry_TextChanged"/>
            </Grid>

            <CheckBox x:Name="ShowPasswordCheck" Content="Show password" Margin="0,8,0,0"
                      Foreground="{DynamicResource SecondaryTextBrush}"
                      Checked="ShowPasswordCheck_Changed" Unchecked="ShowPasswordCheck_Changed"/>

            <TextBlock x:Name="ErrorText" Foreground="{DynamicResource ErrorBrush}" TextWrapping="Wrap"
                       FontSize="12" Margin="0,10,0,0" Visibility="Collapsed"/>
        </StackPanel>

        <!-- Buttons -->
        <Border Grid.Row="2" Padding="24,12,24,16">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="DecryptButton" Content="Decrypt" Style="{StaticResource DecryptPrimaryButton}"
                        Margin="0,0,10,0" IsDefault="True" Click="DecryptButton_Click"/>
                <Button Content="Cancel" Style="{StaticResource DecryptCancelButton}" IsCancel="True" Click="CancelButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
